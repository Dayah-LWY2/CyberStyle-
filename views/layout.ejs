<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="CyberStyle - Discover the Future of Fashion">
    <meta name="keywords" content="fashion, online store, shop, men, women, kids, clothing">
    <meta name="theme-color" content="#333333">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="icon" href="/images/cyberstyle-icon.png">
    <title><%= title || 'CyberStyle' %></title>
</head>
<body>
    <header>
        <div class="logo">
            <h1>CyberStyle</h1>
        </div>      

        <!--Start of Tawk.to Script-->
        <script type="text/javascript">
            var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
            (function(){
            var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
            s1.async=true;
            s1.src='https://embed.tawk.to/67036a5537379df10df3162e/1i9ileob7';
            s1.charset='UTF-8';
            s1.setAttribute('crossorigin','*');
            s0.parentNode.insertBefore(s1,s0);
            })();
        </script>
        <!--End of Tawk.to Script-->     

        <div class="search-bar-container">
            <form id="search-form" action="/search" method="get" autocomplete="off">
                <input type="text" name="q" id="search-bar" placeholder="Search for products or pages..." value="<%= typeof query !== 'undefined' ? query : '' %>">
                
                <select name="filter" id="filter-options">
                    <option value="">Filter</option>
                    <option value="price-asc" <%= filter === 'price-asc' ? 'selected' : '' %>>Cheapest</option>
                    <option value="price-desc" <%= filter === 'price-desc' ? 'selected' : '' %>>Most Expensive</option>
                    <option value="date-popular" <%= filter === 'date-popular' ? 'selected' : '' %>>Popular</option>
                    <option value="date-latest" <%= filter === 'date-latest' ? 'selected' : '' %>>Latest</option>
                    <option value="date-oldest" <%= filter === 'date-oldest' ? 'selected' : '' %>>Oldest</option>
                </select>
                
                <button type="submit" id="search-btn">Search</button>
            </form>
            <div id="suggestion-box" class="search-dropdown"></div>
        </div>
        
        <!-- Hamburger menu for mobile -->
        <div class="hamburger-menu" aria-label="Open Menu">
            <div></div>
            <div></div>
            <div></div>
        </div>

        <!-- Sidebar for mobile navigation -->
        <nav class="sidebar mobile-nav">
            <div class="close-btn" aria-label="Close Menu">&times;</div>
            <a href="/">Home</a>
            <div class="submenu">
                <a href="#">Shop All</a>
                <ul class="dropdown">
                    <li><a href="/women">Women</a></li>
                    <li><a href="/men">Men</a></li>
                    <li><a href="/kids">Kids</a></li>
                </ul>
            </div>
            <a href="/profile">Profile</a>
            <a href="/purchased">Order</a>
                <% if (username) { %>
                    <a href="/logout">Sign Out</a>
                <% } else { %>
                    <a href="/login">Log In</a>
                <% } %>
            <a href="/cart">ðŸ›’</a>
        </nav>

        <!-- Standard navigation for larger screens -->
        <nav class="main-menu desktop-nav">
            <ul class="menu">
                <li><a href="/">Home</a></li>
                <li class="submenu">
                    <a href="/products">Shop All</a>
                    <ul class="dropdown">
                        <li><a href="/women">Women</a></li>
                        <li><a href="/men">Men</a></li>
                        <li><a href="/kids">Kids</a></li>
                    </ul>
                </li>
                <li><a href="/cart">ðŸ›’</a></li>
                <li class="submenu">
                    <a href="/profile">Profile</a>
                    <ul class="dropdown">
                        <li><a href="/purchased">Order</a></li>
                        <li><% if (username) { %>
                            <a href="/logout">Sign Out</a>
                        <% } else { %>
                            <a href="/login">Log In</a>
                        </li><% } %>
                    </ul>
                </li>
                <li><a href="/about">About</a></li>
            </ul>
        </nav>

    </header>

    <!-- Main content -->
    <main>
        
        <%- body %>    

        <div id="logged-out-popup" class="popup">
            <div class="popup-content">
                <div class="checkmark">âœ“</div>
                <p>You have been logged out</p>
            </div>
        </div>
        <div id="logged-in-popup" class="popup">
            <div class="popup-content">
                <div class="checkmark">âœ“</div>
                <p>Welcome! You have successfully signed in</p>
            </div>
        </div>
        <div id="signed-up-popup" class="popup">
            <div class="popup-content">
                <div class="checkmark">âœ“</div>
                <p>Welcome! You have successfully signed up</p>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-container">
            <div class="footer-column">
                <p>Customer Care</p>
                <a href="/faq">FAQ</a>
                <a href="/shipping-&-returns">Shipping & Returns</a>
                <a href="/store-policy">Store Policy</a>
            </div>
            <div class="footer-column">
                <p>The Company</p>
                <a href="/about">About</a>
            </div>
        </div>
        <br>
        <p>&copy; 2024 CyberStyle</p>
    </footer>

    <!-- Script files -->
    <script src="/js/script.js"></script>
</body>
</html>
